{
  "extends": "./tsconfig",
  "compilerOptions": {
    "sourceMap": false,
    "rootDir": "./src",
    "tsBuildInfoFile": "./lib/.tsbuildinfo"
  },
  "exclude": [
    "src/demo",
    "src/__tests__",
    "src/**/__demos__/**/*.*",
    "src/**/__tests__/**/*.*",
    "src/**/__bench__/**/*.*",
    "src/**/__mocks__/**/*.*",
    "src/**/__jest__/**/*.*",
    "src/**/__mocha__/**/*.*",
    "src/**/__tap__/**/*.*",
    "src/**/__tape__/**/*.*",
    "*.test.ts",
    "*.spec.ts"
  ],
  "references": [
    {
      "path": "../base64/tsconfig.build.json"
    },
    {
      "path": "../keyboard/tsconfig.build.json"
    },
    {
      "path": "../buffers/tsconfig.build.json"
    },
    {
      "path": "../json-expression/tsconfig.build.json"
    },
    {
      "path": "../json-pack/tsconfig.build.json"
    },
    {
      "path": "../json-pointer/tsconfig.build.json"
    },
    {
      "path": "../json-type/tsconfig.build.json"
    },
    {
      "path": "../util/tsconfig.build.json"
    }
  ]
}
