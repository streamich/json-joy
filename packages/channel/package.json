{
  "name": "@jsonjoy.com/channel",
  "publishConfig": {
    "access": "public"
  },
  "version": "18.0.0",
  "description": "Communication channel between processes or even different machines.",
  "author": {
    "name": "streamich",
    "url": "https://github.com/streamich"
  },
  "homepage": "https://github.com/streamich/json-joy/tree/master/packages/channel",
  "repository": {
    "type": "git",
    "url": "https://github.com/streamich/json-joy.git",
    "directory": "packages/channel"
  },
  "license": "AGPL-3.0-only",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/streamich"
  },
  "keywords": [
    "channel",
    "communication",
    "process",
    "machine",
    "socket",
    "ipc",
    "json",
    "joy"
  ],
  "dependencies": {
    "@jsonjoy.com/buffers": "workspace:*",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "tslib": "*"
  },
  "engines": {
    "node": ">=10.0"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "files": [
    "LICENSE",
    "lib/"
  ],
  "scripts": {
    "clean": "npx rimraf lib typedocs coverage gh-pages yarn-error.log",
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b --noEmit",
    "test": "jest --maxWorkers 7"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      ".*/node_modules/.*"
    ],
    "testRegex": ".*/(__tests__|__jest__|demo)/.*(?<!\\.vi)\\.(test|spec)\\.tsx?$",
    "rootDir": ".",
    "testPathIgnorePatterns": [
      "node_modules",
      "\\.vi\\.(test|spec)\\.tsx?$"
    ]
  }
}
